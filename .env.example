NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga4_measurement_id_here

# HubSpot — the contact form creates a Contact + Deal in your CRM.
# Create a Private App in HubSpot (Settings → Integrations → Private Apps) with
# scopes: crm.objects.contacts.read, crm.objects.contacts.write, crm.objects.deals.write.
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
# Optional — defaults to the default sales pipeline / first stage if unset.
HUBSPOT_DEAL_PIPELINE=default
HUBSPOT_DEAL_STAGE=appointmentscheduled
